            "remote control",
            "television"
        ],
        "license": "MIT",
        "platform": "Javascript/Node.js",
        "main": "main.js",
        "icon": "sky-remote.png",
        "enabled": true,
        "extIcon": "https://raw.githubusercontent.com/yourusername/iobroker.sky-remote/master/admin/sky-remote.png",
        "readme": "https://github.com/yourusername/iobroker.sky-remote/blob/master/README.md",
        "loglevel": "info",
        "mode": "daemon",
        "type": "multimedia",
        "compact": true,
        "connectionType": "local",
        "dataSource": "poll",
        "materialize": true,
        "dependencies": [
            {
                "js-controller": ">=3.3.0"
            }
        ]
    },
    "native": {
        "host": "",
        "port": 49160,
        "connectionCheckFrequency": 60000
    },
    "objects": [],
    "instanceObjects": [
        {
            "_id": "info",
            "type": "channel",
            "common": {
                "name": "Information"
            },
            "native": {}
        },
        {
            "_id": "info.connection",
            "type": "state",
            "common": {
                "role": "indicator.connected",
                "name": "Connected to Sky box",
                "type": "boolean",
                "read": true,
                "write": false,
                "def": false
            },
            "native": {}
        },
        {
            "_id": "buttons",
            "type": "channel",
            "common": {
                "name": "Remote Buttons"
            },
            "native": {}
        },
        {
            "_id": "sendSequence",
            "type": "state",
            "common": {
                "name": "Send Command Sequence",
                "type": "string",
                "role": "text",
                "read": true,
                "write": true,
                "desc": "Send a sequence of commands separated by comma (e.g. \"home,right,select\")"
            },
            "native": {}
        }
    ]
}